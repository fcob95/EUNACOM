# ── Supabase ──────────────────────────────────────────────────────────
# Crea un proyecto en https://supabase.com y copia estos valores desde
# Project Settings → API. Luego copia este archivo a .env.local (NUNCA
# commitees .env.local).
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Supabase CLI / MCP (solo desarrollo local, no expuesto al browser) ─
# Personal access token para el MCP server de Supabase y el CLI.
# Genera uno en https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...
# Ref del proyecto (el subdominio de la URL)
SUPABASE_PROJECT_REF=TU-PROYECTO

# IMPORTANTE:
# 1. Habilita "Anonymous sign-ins" en Authentication → Providers.
# 2. Corre las migraciones de supabase/migrations/ y luego supabase/seed.sql.
